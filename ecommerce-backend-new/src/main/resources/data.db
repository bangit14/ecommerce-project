INSERT INTO products (id, active, brand, created_at, description, name, slug, updated_at, weight, primary_category_id) VALUES
(1, TRUE, 'Zara', '2023-05-24 07:06:00.000', 'Áo thun basic cổ tròn tay ngắn. Sản phẩm chính hãng Zara, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo thun basic cổ tròn tay ngắn', 'ao-thun-basic-co-tron-tay-ngan-1', '2023-11-14 07:06:00.000', 0.24, 25),
(2, TRUE, 'H&M', '2023-06-14 06:27:00.000', 'Áo sơ mi linen dài tay nữ. Sản phẩm chính hãng H&M, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo sơ mi linen dài tay nữ', 'ao-so-mi-linen-dai-tay-nu-2', '2023-09-10 06:27:00.000', 0.37, 25),
(3, TRUE, 'Uniqlo', '2023-03-23 15:55:00.000', 'Áo croptop thun gân co giãn. Sản phẩm chính hãng Uniqlo, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo croptop thun gân co giãn', 'ao-croptop-thun-gan-co-gian-3', '2023-04-18 15:55:00.000', 0.18, 25),
(4, TRUE, 'Mango', '2023-08-23 09:51:00.000', 'Áo kiểu hoa nhí cổ bèo nữ. Sản phẩm chính hãng Mango, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo kiểu hoa nhí cổ bèo nữ', 'ao-kieu-hoa-nhi-co-beo-nu-4', '2023-11-12 09:51:00.000', 0.25, 25),
(5, TRUE, 'Canifa', '2023-02-18 11:09:00.000', 'Áo len dệt kim cổ lọ nữ. Sản phẩm chính hãng Canifa, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo len dệt kim cổ lọ nữ', 'ao-len-det-kim-co-lo-nu-5', '2023-07-29 11:09:00.000', 0.45, 25),
(6, TRUE, 'Local Brand', '2023-10-28 21:10:00.000', 'Áo thun oversize unisex form rộng. Sản phẩm chính hãng Local Brand, chất lượng cao, giá tốt nhất tại Shopee. Giao hàng nhanh toàn quốc.', 'Áo thun oversize unisex form rộng', 'ao-thun-oversize-unisex-form-rong-6', '2024-02-22 21:10:00.000', 0.24, 25),
